# === LLM Provider ===
# Options: claude (default), grok, gemini
LLM_PROVIDER=claude
# Optional: override the default model for your chosen provider
# LLM_MODEL=

# === Anthropic (Claude AI) — required when LLM_PROVIDER=claude ===
ANTHROPIC_API_KEY=sk-ant-...

# === xAI — required for the voice bridge (always) and when LLM_PROVIDER=grok ===
# XAI_API_KEY=xai-...
# XAI_VOICE_MODEL=grok-voice-think-fast-1.0
# XAI_VOICE_COST_PER_MINUTE=0.05   # update from x.ai/api/voice pricing page

# === Google (Gemini) — required when LLM_PROVIDER=gemini ===
# GOOGLE_API_KEY=AIza...

# === Twilio (required) ===
# Sign up at twilio.com, get a phone number, set voice webhook to
# https://your-domain/voice/incoming and status callback to
# https://your-domain/voice/status
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+15551234567

# === Telegram Notifications ===
# Create a bot via @BotFather, get the token. Send a message to the bot,
# then use https://api.telegram.org/bot<token>/getUpdates to find your chat ID.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# === Data ===
# Directory for call history persistence (default: data)
# DATA_DIR=data

# === Agent Settings ===
AGENT_NAME=YourName
OWNER_NAME=Your Full Name
BASE_URL=https://your-domain.example.com

# === Environment ===
# Set to "development" to enable /docs endpoint. Defaults to "production".
ENVIRONMENT=production
