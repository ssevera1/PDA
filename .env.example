# === LLM Provider ===
# Options: claude (default), grok, gemini
LLM_PROVIDER=claude
# Optional: override the default model for your chosen provider
# LLM_MODEL=

# === Anthropic (Claude AI) — required when LLM_PROVIDER=claude ===
ANTHROPIC_API_KEY=sk-ant-...

# === xAI (Grok) — required when LLM_PROVIDER=grok ===
# XAI_API_KEY=xai-...

# === Google (Gemini) — required when LLM_PROVIDER=gemini ===
# GOOGLE_API_KEY=AIza...

# === SMTP Email Notifications ===
# Leave blank to disable email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=app-password-here
SMTP_FROM=you@gmail.com
NOTIFICATION_EMAIL=owner@example.com

# === Dashboard ===
# Required to access /dashboard and /api/dashboard/* endpoints
DASHBOARD_API_KEY=change-me-to-a-strong-random-key

# === Data ===
# Directory for call history persistence (default: data)
# DATA_DIR=data

# === Agent Settings ===
AGENT_NAME=Sophie
OWNER_NAME=Boss
BASE_URL=https://your-domain.example.com

# === Environment ===
# Set to "development" to enable /docs endpoint. Defaults to "production".
ENVIRONMENT=production
