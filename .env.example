# === LLM Provider ===
# Options: claude (default), grok, gemini
LLM_PROVIDER=claude
# Optional: override the default model for your chosen provider
# LLM_MODEL=

# === Anthropic (Claude AI) — required when LLM_PROVIDER=claude ===
ANTHROPIC_API_KEY=sk-ant-...

# === xAI (Grok) — required when LLM_PROVIDER=grok ===
# XAI_API_KEY=xai-...

# === Google (Gemini) — required when LLM_PROVIDER=gemini ===
# GOOGLE_API_KEY=AIza...

# === Twilio ===
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# === Telegram Notifications ===
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# === Agent Settings ===
AGENT_NAME=Sophie
OWNER_NAME=Boss
BASE_URL=https://your-domain.ngrok-free.app

# === Environment ===
# Set to "development" to enable /docs endpoint. Defaults to "production".
ENVIRONMENT=production
